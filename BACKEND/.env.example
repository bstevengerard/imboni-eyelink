# IMBONI EyeLink Backend - Environment Variables (edit for your deployment)

# --- Database ---
# Used by BACKEND/db_config.js and BACKEND/fix-db.js
MONGO_URI=

# --- Server / Runtime ---
PORT=5000
JWT_SECRET=imboni-eyelink-secret
FRONTEND_URL=http://localhost:8080

# --- Security / Message encryption ---
# Used for encrypting/decrypting chat messages in BACKEND/server.js and BACKEND/db_config.js
MESSAGE_ENCRYPTION_KEY=dev-only-insecure-change-me-32bytes-min

# --- CORS ---
# Comma-separated list of allowed origins (e.g. "http://localhost:8080,https://your-frontend.com")
# If empty/unset, backend will allow "*" via corsOrigins logic.
CORS_ORIGIN=

# --- Google Meet (Spaces API) ---
# Optional - if not set, meeting space creation will fall back to a generic "new" link.
GOOGLE_MEET_PROJECT_ID=
GOOGLE_MEET_CLIENT_EMAIL=
GOOGLE_MEET_PRIVATE_KEY=
GOOGLE_MEET_PRIVATE_KEY_ID=
GOOGLE_MEET_CLIENT_ID=
GOOGLE_MEET_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_MEET_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_MEET_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_MEET_CLIENT_X509_CERT_URL=
GOOGLE_MEET_UNIVERSE_DOMAIN=googleapis.com

# Optional overrides
GOOGLE_MEET_KEYFILE_PATH=./credentials.json
GOOGLE_MEET_TEST_ROOM=

# --- Notes ---
# BACKEND/server.js has a built-in Super Admin credential check (hardcoded).
# Do not store real production admin passwords in .env unless you modify the code.
