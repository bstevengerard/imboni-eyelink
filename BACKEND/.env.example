# Backend Configuration
PORT=5000
JWT_SECRET=imboni-eyelink-secret
MONGO_URI=mongodb://localhost:27017/imboni_eyelink

# Frontend URL - used for HTML exports and verification emails
# Local development: http://localhost:8080
# Production: https://imboni-eyelink.vercel.app
FRONTEND_URL=http://localhost:8080

# CORS Origins - comma-separated list of allowed origins
FRONTEND_URL_FOR_CORS=https://imboni-eyelink.vercel.app,https://imbonieyelink.org,http://localhost:8080,http://localhost:5173,http://localhost:3000

# Google Meet (Service Account) - optional, only needed for teleconsultation features
GOOGLE_MEET_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_MEET_PROJECT_ID=your-project-id
GOOGLE_MEET_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_MEET_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE
-----END PRIVATE KEY-----"

# DEVELOPMENT: Set a valid room code from a real Google Meet meeting
GOOGLE_MEET_TEST_ROOM=your-test-room-code